{
  "name": "armstrong-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js (NestJS) + PostgreSQL backend for Armstrong gym tracker — auth and plan sync.",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "admin:create": "node scripts/create-admin.cjs",
    "seed:exercises": "node scripts/seed-exercises.cjs",
    "test": "prisma generate && jest",
    "lint": "eslint \"src/**/*.ts\""
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.0.0",
    "google-auth-library": "^10.7.0",
    "jose": "^5.9.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prisma": "^6.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  }
}
