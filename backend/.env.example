# --- Local / Docker (long-running server, src/main.ts) ---
# Plain Postgres connection. For local dev DATABASE_URL and DIRECT_URL are the same.
DATABASE_URL="postgresql://armstrong:armstrong@localhost:5432/armstrong?schema=public"
DIRECT_URL="postgresql://armstrong:armstrong@localhost:5432/armstrong?schema=public"

# --- Vercel serverless + Neon (production) ---
# DATABASE_URL = Neon POOLED connection (host has "-pooler"), used by the running
#   function. Append connection-pool params, e.g.:
#   postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/armstrong?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL   = Neon DIRECT connection (no "-pooler"), used by `prisma migrate`:
#   postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/armstrong?sslmode=require

# Secret used to sign app-user JWT access tokens. Long random string in prod.
JWT_SECRET="change-me-in-production"

# How long an app-user access token stays valid.
JWT_EXPIRES_IN="30d"

# SEPARATE secret for admin JWTs (admin app). Must differ from JWT_SECRET.
ADMIN_JWT_SECRET="change-me-admin-secret"

# Admin token lifetime (shorter than user tokens by design).
ADMIN_JWT_EXPIRES_IN="12h"

# Port the API listens on (local/Docker only; ignored on Vercel).
PORT=4000

# Cloudinary — media (exercise images/video) uploads from the admin app.
# Free account at https://cloudinary.com → Dashboard shows these three values.
# Without them, uploads are disabled (seed images still work).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth — accepted audiences (client IDs) for "Sign in with Google".
# Comma-separated: web client ID + iOS client ID + Android client ID as you add
# native sign-in. Same web ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend.
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_IDS=

# Apple Sign in — accepted audiences. The iOS app's bundle id (e.g.
# com.armstrong.app) and, for web, your Services ID. Comma-separated.
APPLE_CLIENT_IDS=

# Comma-separated allowed CORS origins (the frontend URLs).
# Production example: https://armstrong.vercel.app,capacitor://localhost,http://localhost
CORS_ORIGINS="http://localhost:3000"
