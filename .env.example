# GitHub Pages subpath (set automatically in CI)
# NEXT_PUBLIC_BASE_PATH=/armstrong

# App store links (optional)
# NEXT_PUBLIC_APP_STORE_URL=
# NEXT_PUBLIC_PLAY_STORE_URL=

# Google Gemini Flash — get a free key at https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# Supabase — create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL editor after creating the project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override model (defaults to free-tier flash models)
# NEXT_PUBLIC_GEMINI_MODEL=gemini-3.5-flash

# Optional: USDA FoodData Central key for meal search (defaults to DEMO_KEY)
# Get a free key at https://fdc.nal.usda.gov/api-key-signup
# NEXT_PUBLIC_USDA_API_KEY=
