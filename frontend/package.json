{
  "name": "armstrong",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:sync": "node scripts/sync-locale-structure.mjs",
    "i18n:translate": "node scripts/translate-locales.mjs",
    "blog:images": "node scripts/generate-blog-images.mjs",
    "cap:sync": "next build && cap sync && node scripts/patch-native-entry.mjs",
    "android": "next build && cap sync android && node scripts/patch-native-entry.mjs && CAPACITOR_ANDROID_STUDIO_PATH=$HOME/.local/bin/android-studio cap open android",
    "ios": "next build && cap sync ios && node scripts/patch-native-entry.mjs && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-social-login": "^8.3.30",
    "@google/genai": "^2.10.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "i18next": "^26.3.2",
    "next": "^15.3.3",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "sharp": "^0.35.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
