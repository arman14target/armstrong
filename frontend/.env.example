# GitHub Pages subpath (set automatically in CI)
# NEXT_PUBLIC_BASE_PATH=/armstrong

# Production site URL — used for sitemap, canonical, and Open Graph URLs
# NEXT_PUBLIC_SITE_URL=https://armstrong-fitness.com

# App store links (optional)
# NEXT_PUBLIC_APP_STORE_URL=
# NEXT_PUBLIC_PLAY_STORE_URL=

# Google Gemini — coach chat only
# Get a free key at https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# Armstrong backend — Node.js (NestJS) + PostgreSQL API for auth + cloud sync.
# Point this at the running backend (see backend/ and docker-compose.yml).
# Leave empty to run the app on localStorage only (no login / no sync).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Sign in with Google — Web OAuth client ID (same value the backend accepts in
# GOOGLE_CLIENT_IDS). https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# iOS OAuth client ID for the native app (also add it to backend GOOGLE_CLIENT_IDS).
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Sign in with Apple (web) — Services ID + an authorized redirect URL. Both
# required to show the Apple button on the web app.
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=

# Optional: override model (defaults to free-tier flash models)
# NEXT_PUBLIC_GEMINI_MODEL=gemini-3.5-flash

# Optional: USDA FoodData Central key for meal search (defaults to DEMO_KEY)
# Get a free key at https://fdc.nal.usda.gov/api-key-signup
# NEXT_PUBLIC_USDA_API_KEY=

# Cloudflare Workers AI — blog hero images only (npm run blog:images)
# Each developer uses their own token from Workers AI → Use REST API
# Generated images live in public/images/blog/ and are committed; no key needed to build/run the app.
# https://developers.cloudflare.com/workers-ai/get-started/rest-api/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional: override image model (default: @cf/black-forest-labs/flux-1-schnell)
# For 16:9 output use: @cf/black-forest-labs/flux-2-klein-4b
# CLOUDFLARE_IMAGE_MODEL=
